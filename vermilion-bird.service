[Unit]
Description=Vermilion Bird - LLM Chat Client
Documentation=https://github.com/your-org/vermilion-bird
After=network.target

[Service]
Type=simple
User=%USER%
Group=%GROUP%
WorkingDirectory=/path/to/vermilion-bird

# 使用 Python venv 运行
ExecStart=/path/to/vermilion-bird/.venv/bin/vermilion-bird

# 或者使用 Python 模块方式（取消注释以下行并注释上面的 ExecStart）
# ExecStart=/path/to/vermilion-bird/.venv/bin/python -m llm_chat.cli

# 环境变量
Environment="LLM_API_KEY=your-api-key-here"
# Environment="LLM_BASE_URL=https://api.openai.com/v1"
# Environment="LLM_MODEL=gpt-3.5-turbo"
# Environment="LLM_PROTOCOL=openai"

# 重启策略
Restart=on-failure
RestartSec=10

# 日志
StandardOutput=journal
StandardError=journal
SyslogIdentifier=vermilion-bird

# 资源限制（可选）
# LimitNOFILE=65536
# MemoryMax=1G

[Install]
WantedBy=multi-user.target
